
### Register a new user
POST http://localhost:8080/auth/register
Content-Type: application/json

{
  "name": "John Doe",
  "email": "johndoe@example.com",
  "password": "password123"
}

### Login with the new user
# @name login
POST http://localhost:8080/auth/login
Content-Type: application/json

{
  "email": "johndoe@example.com",
  "password": "password123"
}

@token = {{login.response.body.token}}

### Refresh the access token
PATCH http://localhost:8080/token/refresh
Content-Type: application/json

@newToken = {{refresh.response.body.token}}

### Get user profile
GET http://localhost:8080/users/me
Authorization: Bearer {{token}}

### Create a gym (Admin only)
# @name createGym
POST http://localhost:8080/gyms
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "JS Academy",
  "description": "Some description",
  "phone": "1199999999",
  "latitude": -27.2092052,
  "longitude": -49.6401091
}

@gymId = {{createGym.response.body.id}}

### Create a check-in
# @name createCheckIn
POST http://localhost:8080/check-ins/{{gymId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "latitude": -27.2092052,
  "longitude": -49.6401091
}

@checkInId = {{createCheckIn.response.body.id}}

### Validate a check-in (Admin only)
PATCH http://localhost:8080/check-ins/validate/{{checkInId}}
Authorization: Bearer {{token}}

### Get own check-in history
GET http://localhost:8080/check-ins/history?page=0&size=20
Authorization: Bearer {{token}}

### Search gyms by name (Public)
GET http://localhost:8080/gyms/search?q=JS&page=0&size=20

### Search nearby gyms (Public)
GET http://localhost:8080/gyms/nearby?latitude=-27.2092052&longitude=-49.6401091
